FROM continuumio/miniconda3:23.9.0-0

ARG DEBIAN_FRONTEND=noninteractive

# 1. Install system dependencies as root
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

# 2. Install Python packages as root so they land in the system (conda) site-packages,
#    accessible to any user regardless of UID at runtime.
COPY requirements.txt /tmp/requirements.txt
RUN pip install --upgrade pip && \
    grep -E 'aind-data-schema|aind-nwb-utils|hdmf-zarr|pynwb|pytz|neuroconv|wavpack-numcodecs|neo' /tmp/requirements.txt | xargs pip install

RUN SPIKEINTERFACE_VERSION=$(grep '^spikeinterface==' /tmp/requirements.txt | cut -d'=' -f3) && \
    pip install "spikeinterface[full]==${SPIKEINTERFACE_VERSION}"

# 3. Create non-root user for runtime
RUN useradd -m -u 1000 pipelineuser

# 4. Setup work area
WORKDIR /home/pipelineuser

# 5. Switch to non-root user
USER pipelineuser

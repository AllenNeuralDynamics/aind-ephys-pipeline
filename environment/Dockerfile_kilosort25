FROM spikeinterface/kilosort2_5-compiled-base:latest

ARG DEBIAN_FRONTEND=noninteractive

# Note: KS2.5 base image (built from MATLAB) already provides 'appuser' with UID 1000.

# 1. Install Python packages as root so they land in the system site-packages,
#    accessible to any user regardless of UID at runtime.
USER root
COPY requirements.txt /tmp/requirements.txt
RUN pip install --upgrade pip && \
    grep -E 'aind-data-schema|scipy' /tmp/requirements.txt | xargs pip install

RUN SPIKEINTERFACE_VERSION=$(grep '^spikeinterface==' /tmp/requirements.txt | cut -d'=' -f3) && \
    pip install "spikeinterface[full]==${SPIKEINTERFACE_VERSION}"

# 2. Ensure appuser owns their home directory and switch to non-root user
RUN chown -R appuser:appuser /home/appuser
WORKDIR /home/appuser
USER appuser

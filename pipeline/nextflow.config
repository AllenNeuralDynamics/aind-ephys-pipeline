process { 
    executor = 'awsbatch' 
    queueSize = 100
}

process.resourceLabels = ['allen-batch-pipeline': 'aind-ephys-pipeline-kilosort4']

process { 
  withName: postprocessing { 
    containerOptions = '--memory-swap 240000 --memory-swappiness 20 --shm-size 16000000' 
  }
  withName: spikesort_kilosort4 {
    errorStrategy = 'retry'
    maxRetries = 3
    maxErrors = 5
  }
  withName: quality_control { 
    containerOptions = '--memory-swap 240000 --memory-swappiness 20 --shm-size 16000000'
    errorStrategy = 'ignore'
  }
}

env.PIPELINE_URL = "https://github.com/AllenNeuralDynamics/aind-ephys-pipeline"
env.PIPELINE_VERSION = "kilosort4_1.0.0"
env.DATA_PATH = 's3://aind-ephys-data/ecephys_713593_2024-02-08_14-10-37'